{
  "version": "1.0",
  "description": "Security guardrails for the Security Remediation Agent",
  "forbidden_actions": [
    {
      "action": "force-push",
      "branches_affected": ["main", "master", "develop"],
      "reason": "Prevents history rewrite or destruction",
      "severity": "critical"
    },
    {
      "action": "delete-branch",
      "reason": "Prevent data loss without approval",
      "severity": "high"
    },
    {
      "action": "push-secrets",
      "reason": "Security violation - credentials must not be exposed",
      "severity": "critical"
    },
    {
      "action": "execute-arbitrary-code",
      "reason": "Prevent agent compromise via external code execution",
      "severity": "critical"
    },
    {
      "action": "modify-cicd",
      "reason": "Prevent workflow hijacking",
      "severity": "high"
    },
    {
      "action": "access-outside-scope",
      "reason": "Prevent lateral movement to unrelated repositories",
      "severity": "critical"
    },
    {
      "action": "commit-to-protected",
      "reason": "Enforce PR review for protected branches",
      "severity": "high"
    },
    {
      "action": "disable-security",
      "reason": "Prevent weakening of security features",
      "severity": "critical"
    }
  ],
  "allowed_scanners": [
    "trivy",
    "bandit",
    "pip-audit",
    "semgrep",
    "gitleaks"
  ],
  "file_restrictions": {
    "read_only_patterns": [],
    "write_allowed_patterns": ["**/*"],
    "never_modify": [
      "**/.github/workflows/*",
      "**/Jenkinsfile",
      "**/.gitlab-ci.yml"
    ]
  },
  "validation": {
    "require_verification_gate": true,
    "require_tests_pass": true
  }
}
